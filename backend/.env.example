PORT=3000
NODE_ENV=development

# Supabase pooler
# App uses the TRANSACTION pooler (port 6543) — short-lived txns, friendly to serverless and many concurrent requests.
# Prisma migrate / introspect uses the SESSION pooler (port 5432) via DIRECT_URL.
DATABASE_URL="postgresql://user:password@host:6543/postgres?pgbouncer=true&connection_limit=1&pool_timeout=30&sslmode=require"
DIRECT_URL="postgresql://user:password@host:5432/postgres?sslmode=require"
CORS_ORIGINS="http://localhost:5173,http://localhost:8080"

# Stellar testnet
SOROBAN_RPC_URL="https://soroban-testnet.stellar.org"
HORIZON_URL="https://horizon-testnet.stellar.org"
SOROBAN_NETWORK_PASSPHRASE="Test SDF Network ; September 2015"

# JWT secret
JWT_SECRET="replace-with-a-long-random-secret"
JWT_EXPIRES_IN="7d"

# Organizer
ORGANIZER_SECRET=""
ORGANIZER_PUBLIC=""

# QR/NFT metadata
QR_SIGNING_SECRET="replace-with-a-different-long-random-secret"
ALLOW_LEGACY_TICKET_ID_SCAN=false
PUBLIC_BASE_URL="https://your-frontend-domain.example"
ISSUER_HOME_DOMAIN="your-frontend-domain.example"

# Indexer
RUN_INDEXER=false # false para desarrollo, true para produccion
